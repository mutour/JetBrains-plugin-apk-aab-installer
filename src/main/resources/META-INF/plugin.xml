<idea-plugin>
    <id>com.kip2.apkinstaller</id>
    <name>Apk/Aab Installer</name>
    <version>1.0.0</version>
    <vendor url="https://www.yourcompany.com">KIP2</vendor>
    <description>Install APK/AAB files to Android devices directly from IDE</description>

    <depends>com.intellij.modules.platform</depends>
    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.compose</depends>

    <resource-bundle>messages.InstallerBundle</resource-bundle>

    <applicationListeners>
    </applicationListeners>
    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="ApkInstaller.NotificationGroup" displayType="BALLOON" bundle="messages.InstallerBundle" key="apk.installer.notification.group"/>
        <applicationService serviceImplementation="com.kip2.apkinstaller.settings.PluginSettings"/>
        <toolWindow id="ApkInstaller" factoryClass="com.kip2.apkinstaller.toolwindow.MyToolWindowFactory"
                    icon="AllIcons.Toolwindows.ToolWindowPalette"/>
    </extensions>

    <actions>
        <action id="InstallApkAction" class="com.kip2.apkinstaller.actions.InstallAction">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="first"/>
            <add-to-group group-id="EditorTabPopupMenu" anchor="first"/>
        </action>
    </actions>
</idea-plugin>
